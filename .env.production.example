# Production Environment Variables
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to git!

# Database Configuration
DB_USER=workoutuser
DB_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
DB_NAME=workout_tracker

# JWT Configuration
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=https://workout.nikobjelic.com

# Frontend API URL (for Next.js)
# Use the public URL or local backend for internal calls
NEXT_PUBLIC_API_URL=https://workout.nikobjelic.com/api
