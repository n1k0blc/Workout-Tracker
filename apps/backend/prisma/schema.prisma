generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  dateOfBirth   DateTime?
  firstName     String?
  height        Int?
  lastName      String?
  weight        Float?
  exercises     Exercise[]
  homeGyms      HomeGym[]
  workouts      Workout[]
  workoutCycles WorkoutCycle[]
}

model HomeGym {
  id                 String       @id @default(uuid())
  name               String
  userId             String
  createdAt          DateTime     @default(now())
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts           Workout[]
  plannedWorkoutDays WorkoutDay[] @relation("PlannedHomeGym")
}

model WorkoutCycle {
  id          String       @id @default(uuid())
  name        String
  duration    Int
  startDate   DateTime
  status      CycleStatus  @default(ACTIVE)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  userId      String
  workouts    Workout[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays WorkoutDay[]
}

model WorkoutDay {
  id               String            @id @default(uuid())
  weekday          Int
  name             String
  cycleId          String
  plannedHomeGymId String?
  workouts         Workout[]
  blueprint        WorkoutBlueprint?
  cycle            WorkoutCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  plannedHomeGym   HomeGym?          @relation("PlannedHomeGym", fields: [plannedHomeGymId], references: [id])
}

model WorkoutBlueprint {
  id           String              @id @default(uuid())
  workoutDayId String              @unique
  updatedAt    DateTime            @updatedAt
  exercises    BlueprintExercise[]
  workoutDay   WorkoutDay          @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
}

model BlueprintExercise {
  id          String           @id @default(uuid())
  order       Int
  blueprintId String
  exerciseId  String
  blueprint   WorkoutBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  exercise    Exercise         @relation(fields: [exerciseId], references: [id])
  sets        BlueprintSet[]
}

model BlueprintSet {
  id                  String            @id @default(uuid())
  order               Int
  setType             SetType           @default(WORKING)
  reps                Int
  weight              Float
  rir                 Int
  restAfterSet        Int               @default(90)
  blueprintExerciseId String
  blueprintExercise   BlueprintExercise @relation(fields: [blueprintExerciseId], references: [id], onDelete: Cascade)
}

model Workout {
  id            String        @id @default(uuid())
  date          DateTime      @default(now())
  status        WorkoutStatus
  isFreeWorkout Boolean       @default(false)
  totalDuration Int?
  userId        String
  cycleId       String?
  workoutDayId  String?
  createdAt     DateTime      @default(now())
  homeGymId     String?
  exercises     ExerciseLog[]
  cycle         WorkoutCycle? @relation(fields: [cycleId], references: [id])
  homeGym       HomeGym?      @relation(fields: [homeGymId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDay    WorkoutDay?   @relation(fields: [workoutDayId], references: [id])
}

model Exercise {
  id                 String              @id @default(uuid())
  name               String
  muscleGroup        MuscleGroup
  equipment          Equipment
  isCustom           Boolean             @default(false)
  userId             String?
  isDoubleWeight     Boolean             @default(false)
  isUnilateral       Boolean             @default(false)
  blueprintExercises BlueprintExercise[]
  user               User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseLogs       ExerciseLog[]
}

model ExerciseLog {
  id                String   @id @default(uuid())
  order             Int
  workoutId         String
  exerciseId        String
  customPlannedSets Json?
  exercise          Exercise @relation(fields: [exerciseId], references: [id])
  workout           Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets              SetLog[]
}

model SetLog {
  id                 String      @id @default(uuid())
  exerciseLogId      String
  setNumber          Int
  setType            SetType     @default(WORKING)
  targetReps         Int?
  targetWeight       Float?
  targetRir          Int?
  reps               Int
  weight             Float
  rir                Int?
  actualRestDuration Int?
  completedAt        DateTime    @default(now())
  exerciseLog        ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)
}

enum MuscleGroup {
  CHEST
  BACK
  BICEPS
  TRICEPS
  ABS
  SHOULDERS
  LEGS
}

enum Equipment {
  CABLE
  MACHINE
  DUMBBELL
  BARBELL
  BODYWEIGHT
  SMITH_MACHINE
  EZ_BAR
}

enum WorkoutStatus {
  IN_PROGRESS
  COMPLETED
  DISCARDED
}

enum SetType {
  WARMUP
  WORKING
}

enum CycleStatus {
  ACTIVE
  COMPLETED
}

enum GymLocation {
  HOME
  OTHER
}
